generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  type        String
  address     String
  phone       String
  email       String?
  timezone    String       @default("Atlantic/Canary")
  currency    String       @default("EUR")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  ownerId     String?
  agentConfig AgentConfig?
  bookings    Booking[]
  services    Service[]
  staff       Staff[]
}

model Service {
  id              String         @id @default(uuid())
  businessId      String
  name            String
  description     String?
  durationMinutes Int
  price           Float
  colorCode       String         @default("#f43f5e")
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  bookings        Booking[]
  business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffServices   StaffService[]
}

model Staff {
  id            String          @id @default(uuid())
  businessId    String
  name          String
  email         String?
  phone         String?
  avatarUrl     String?
  bio           String?
  colorCode     String          @default("#3b82f6")
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  bookings      Booking[]
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  overrides     StaffOverride[]
  schedules     StaffSchedule[]
  staffServices StaffService[]
}

model StaffService {
  staffId   String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
}

model StaffSchedule {
  id          String @id @default(uuid())
  staffId     String
  weekday     Int
  startMinute Int
  endMinute   Int
  staff       Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, weekday])
}

model StaffOverride {
  id          String  @id @default(uuid())
  staffId     String
  date        String
  isClosed    Boolean @default(false)
  startMinute Int?
  endMinute   Int?
  staff       Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model Customer {
  id        String    @id @default(uuid())
  phone     String    @unique
  email     String?
  name      String
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model AgentConfig {
  id                  String         @id @default(uuid())
  businessId          String         @unique
  agentName           String         @default("Asistente")
  gender              String         @default("female")
  tone                String         @default("friendly")
  personalityTraits   String         @default("")
  voiceType           String         @default("default")
  speakingSpeed       Int            @default(100)
  greeting            String         @default("¡Hola! Soy tu asistente de belleza. ¿En qué puedo ayudarte hoy?")
  farewell            String         @default("¡Gracias por confiar en nosotros! Te esperamos.")
  fallbackMessage     String         @default("Lo siento, no entendí bien. ¿Puedes repetirlo?")
  brandGuidelines     String         @default("")
  specialInstructions String         @default("")
  avatarUrl           String?
  primaryColor        String         @default("#f43f5e")
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now())
  business            Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversations       Conversation[]
}

model Conversation {
  id            String         @id @default(uuid())
  agentId       String
  customerName  String?
  customerPhone String?
  status        String         @default("active")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now())
  messages      AgentMessage[]
  agent         AgentConfig    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AgentMessage {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  text           String
  metadata       String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Booking {
  id                    String    @id @default(uuid())
  businessId            String
  customerId            String?
  customerName          String
  customerPhone         String
  customerEmail         String?
  serviceId             String
  staffId               String
  startsAt              DateTime
  endsAt                DateTime
  status                String    @default("confirmed")
  notes                 String?
  conversationId        String?
  createdAt             DateTime  @default(now())
  depositAmount         Float     @default(0)
  paymentStatus         String    @default("pending")
  stripePaymentIntentId String?
  stripeClientSecret    String?
  business              Business  @relation(fields: [businessId], references: [id])
  customer              Customer? @relation(fields: [customerId], references: [id])
  service               Service   @relation(fields: [serviceId], references: [id])
  staff                 Staff     @relation(fields: [staffId], references: [id])
}

model YogurtLead {
  id            String              @id @default(uuid())
  name          String
  phone         String
  email         String?
  source        String              @default("qr")
  eventLocation String?
  status        String              @default("new")
  orderType     String              @default("one-time")
  address       String?
  deliveredAt   DateTime?
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  subscription  YogurtSubscription?
}

model YogurtSubscription {
  id                   String     @id @default(uuid())
  leadId               String     @unique
  stripeSubscriptionId String     @unique
  stripeCustomerId     String?
  status               String     @default("active")
  frequency            String     @default("weekly")
  nextDelivery         DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  lead                 YogurtLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Product {
  id                   String      @id @default(uuid())
  name                 String
  slug                 String      @unique
  description          String?
  price                Float
  comparePrice         Float?
  imageUrl             String?
  isSubscription       Boolean     @default(false)
  subscriptionInterval String?
  isBundle             Boolean     @default(false)
  bundleItems          String?
  stock                Int         @default(0)
  isActive             Boolean     @default(true)
  sortOrder            Int         @default(0)
  createdAt            DateTime    @default(now())
  orderItems           OrderItem[]
}

model Order {
  id                    String      @id @default(uuid())
  customerName          String
  customerPhone         String
  customerEmail         String?
  address               String
  status                String      @default("pending")
  paymentStatus         String      @default("pending")
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?
  total                 Float
  notes                 String?
  deliveryTimeSlot      String?
  deliveredAt           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  items                 OrderItem[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  total       Float
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  description    String?
  stripeCouponId String    @unique
  discountType   String    @default("percentage")
  discountValue  Float
  maxUses        Int?
  usedCount      Int       @default(0)
  validFrom      DateTime  @default(now())
  validUntil     DateTime?
  eventTag       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
}
